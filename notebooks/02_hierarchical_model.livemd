## Forest Plot (Credible Intervals)

```elixir
alias VegaLite, as: Vl

forest_data =
  for {name, s} <- Enum.sort(summary) do
    %{"param" => name, "mean" => s.mean, "q5" => s.q5, "q95" => s.q95}
  end

Vl.new(width: 500, height: 150, title: "90% Credible Intervals")
|> Vl.data_from_values(forest_data)
|> Vl.layers([
  Vl.new()
  |> Vl.mark(:rule, stroke_width: 2)
  |> Vl.encode_field(:y, "param", type: :nominal)
  |> Vl.encode_field(:x, "q5", type: :quantitative, title: "value")
  |> Vl.encode_field(:x2, "q95"),
  Vl.new()
  |> Vl.mark(:point, filled: true, size: 60, color: "black")
  |> Vl.encode_field(:y, "param", type: :nominal)
  |> Vl.encode_field(:x, "mean", type: :quantitative)
])
```

<!-- livebook:{"output":true} -->

```vega-lite
{"$schema":"https://vega.github.io/schema/vega-lite/v5.json","data":{"values":[{"mean":4.0939848974837245,"param":"alpha","q5":3.749027277557825,"q95":4.40117428671418},{"mean":-0.9104872948026498,"param":"mu_group","q5":-9.610566030379939,"q95":11.976471140629197},{"mean":6.249664149796484,"param":"sigma_group","q5":0.9630633720990481,"q95":12.075906934484728}]},"height":150,"layer":[{"encoding":{"x":{"field":"q5","title":"value","type":"quantitative"},"x2":{"field":"q95"},"y":{"field":"param","type":"nominal"}},"mark":{"strokeWidth":2,"type":"rule"}},{"encoding":{"x":{"field":"mean","type":"quantitative"},"y":{"field":"param","type":"nominal"}},"mark":{"color":"black","filled":true,"size":60,"type":"point"}}],"title":"90% Credible Intervals","width":500}
