## Trace Plots

```elixir
alias VegaLite, as: Vl

for name <- ["mu_group", "sigma_group", "alpha"] do
  samples = Nx.to_flat_list(trace[name]) |> Enum.filter(&is_number/1)
  data = Enum.with_index(samples, fn val, i -> %{"iteration" => i, "value" => val} end)

  Vl.new(width: 600, height: 150, title: "Trace: #{name}")
  |> Vl.data_from_values(data)
  |> Vl.mark(:line, opacity: 0.7)
  |> Vl.encode_field(:x, "iteration", type: :quantitative)
  |> Vl.encode_field(:y, "value", type: :quantitative)
  |> Kino.render()
end
```

